# SOC Dashboard Environment Configuration
# Copy this file to .env and update values before deployment

# PostgreSQL
POSTGRES_USER=soc
POSTGRES_PASSWORD=socpassword
POSTGRES_DB=soc_dashboard

# Application Security
SECRET_KEY=change-me-to-a-strong-random-secret-key-at-least-32-chars

# SentinelOne API (required for data sync)
S1_BASE_URL=https://usea1-partners.sentinelone.net
S1_API_TOKEN=your-sentinelone-api-token

# IOC Enrichment (optional)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
GREYNOISE_API_KEY=

# Initial Admin Account (created on first startup)
ADMIN_EMAIL=admin@soc.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=SOC Admin

# Nginx
NGINX_PORT=80

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Logging
LOG_LEVEL=INFO
